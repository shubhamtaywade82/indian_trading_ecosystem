# Indian Trading Ecosystem - Environment Variables
#
# Copy this file to `.env` in the root directory, or load these variables
# into your environment before running the applications.

########################################
# DhanHQ API Credentials
########################################
# Dhan Client ID / User ID
DHAN_CLIENT_ID=

# Dhan login PIN (4-digit numeric pin, required for TOTP login automation)
DHAN_PIN=

# Base32 TOTP Secret (from your Dhan 2FA setup, required for TOTP login automation)
DHAN_TOTP_SECRET=

# Dhan Auth Mode: totp (automated) | manual (static) | renew | authority
DHAN_AUTH_MODE=totp

# Static Dhan Access Token (only used if DHAN_AUTH_MODE is set to "manual")
DHAN_ACCESS_TOKEN=

# Dhan REST API Base URL
DHANHQ_BASE_URL=https://api.dhan.co/v2

########################################
# Microservices / App Locations
########################################
# Location of the Paper Engine microservice (called by Core Trading)
PAPER_ENGINE_URL=http://localhost:3001

# Rails log level: debug, info, warn, error
RAILS_LOG_LEVEL=info

# Default Rails Ports
# apps/core_trading: 3000
# apps/paper_engine: 3001
PORT=3000

########################################
# PostgreSQL Database URLs (Optional overrides)
########################################
# CORE_TRADING_DATABASE_URL=postgres://postgres:postgres@localhost:5432/core_trading_development
# PAPER_ENGINE_DATABASE_URL=postgres://postgres:postgres@localhost:5432/paper_engine_development
