FROM ruby:3.3-slim

RUN apt-get update -qq && apt-get install -y \
    build-essential libpq-dev postgresql-client \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY shared/ /shared/
COPY apps/paper_engine/Gemfile apps/paper_engine/Gemfile.lock ./
RUN bundle install

COPY apps/paper_engine/ .

EXPOSE 3001

CMD ["bin/rails", "server", "-b", "0.0.0.0", "-p", "3001"]